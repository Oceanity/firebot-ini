{
  "compilerOptions": {
    "outDir": "./dist/",
    "target": "ES2022",
    "module": "nodenext",
    "allowSyntheticDefaultImports": true,
    "noImplicitAny": true,
    "sourceMap": true,
    "moduleResolution": "nodenext",
    "experimentalDecorators": true,
    "resolveJsonModule": true,
    "useUnknownInCatchVariables": false
  },
  "include": ["./src/**/*"]
}
